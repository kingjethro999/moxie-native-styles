{
  "name": "moxie-native-styles",
  "version": "0.1.5",
  "license": "MIT",
  "description": "900+ predefined styles for React Native — configured once, applied everywhere.",
  "keywords": [
    "react-native",
    "react",
    "styling",
    "utility-first",
    "design-system",
    "moxie",
    "styles",
    "ui-kit",
    "zero-runtime",
    "typescript",
    "toast",
    "animations"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.tsx --format cjs,esm --dts --clean",
    "dev": "tsup src/index.tsx --format cjs,esm --watch --dts",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-native": "^0.72.0",
    "react": "^18.0.0",
    "react-native": "^0.72.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "lucide-react-native": "^1.8.0",
    "react-native-svg": "^15.15.4"
  }
}
